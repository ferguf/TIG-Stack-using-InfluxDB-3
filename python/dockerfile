FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for Postgres and building Python extensions
RUN apt-get update && apt-get install -y \
    libpq-dev \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy and install requirements
COPY requirements.txt .
# Install with --user or ensure global path is respected
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# FORCE PATH: This ensures the container sees uvicorn in /usr/local/bin
ENV PATH="/usr/local/bin:${PATH}"

EXPOSE 8000

# Use the full path to uvicorn to be 100% safe
CMD ["python", "-m", "uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]